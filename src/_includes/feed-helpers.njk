{% macro atomFeed(title, description, feedUrl, siteUrl, posts, pageUrl) -%}
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <title>{{ title | xmlEscape | safe }}</title>
  <subtitle>{{ description | xmlEscape | safe }}</subtitle>
  <link href="{{ feedUrl }}" rel="self"/>
  <link href="{{ siteUrl }}"/>
  {%- for post in posts.slice(0,1) | sort(true, false, 'updated_at') %}
  <updated>{{ post.updated_at | rfc3339Date }}</updated>
  {%- endfor %}
  <id>{{ feedUrl }}</id>
  <author>
    <name>{{ site.title }}</name>
  </author>
  {%- for post in posts %}
  <entry>
    <title>{{ (post | feedTitle) | xmlEscape | safe }}</title>
    <link href="{{ siteUrl + (post | localPostUrl) }}"/>
    <updated>{{ post.updated_at | rfc3339Date }}</updated>
    <id>{{ siteUrl + (post | localPostUrl) }}</id>
    <content type="html">{{ post.html | feedHtml | htmlToAbsoluteUrls(pageUrl) | xmlEscape | safe }}</content>
  </entry>
  {%- endfor %}
</feed>
{%- endmacro %}

{% macro rssFeed(title, description, feedUrl, siteUrl, posts, pageUrl) -%}
<?xml version="1.0" encoding="utf-8"?>
<rss version="2.0">
  <channel>
    <title>{{ title | xmlEscape | safe }}</title>
    <link>{{ siteUrl }}/</link>
    <description>{{ description | xmlEscape | safe }}</description>
    {%- for post in posts.slice(0,1) | sort(true, false, 'updated_at') %}
    <lastBuildDate>{{ post.updated_at | rfc822Date }}</lastBuildDate>
    {%- endfor %}
    <atom:link xmlns:atom="http://www.w3.org/2005/Atom" href="{{ feedUrl }}" rel="self" type="application/rss+xml" />
    {%- for post in posts %}
    <item>
      {%- if post | feedTitle %}
      <title>{{ (post | feedTitle) | xmlEscape | safe }}</title>
      {%- endif %}
      <link>{{ siteUrl + (post | localPostUrl) }}</link>
      <guid>{{ siteUrl + (post | localPostUrl) }}</guid>
      <pubDate>{{ post.published_at | rfc822Date }}</pubDate>
      <description>{{ (post | rssDescription) | xmlEscape | safe }}</description>
    </item>
    {%- endfor %}
  </channel>
</rss>
{%- endmacro %}

{% macro jsonFeed(title, description, feedUrl, siteUrl, posts, authorName) -%}
{
  "version": "https://jsonfeed.org/version/1.1",
  "title": {{ title | dump | safe }},
  "home_page_url": {{ (siteUrl + "/") | dump | safe }},
  "feed_url": {{ feedUrl | dump | safe }},
  "description": {{ description | dump | safe }},
  "authors": [
    {
      "name": {{ authorName | dump | safe }},
      "url": {{ siteUrl | dump | safe }}
    }
  ],
  "items": [
    {%- for post in posts %}
    {
      "id": {{ (siteUrl + (post | localPostUrl)) | dump | safe }},
      "url": {{ (siteUrl + (post | localPostUrl)) | dump | safe }},
      {%- if post | feedTitle %}
      "title": {{ (post | feedTitle) | dump | safe }},
      {%- endif %}
      "content_html": {{ post.html | feedHtml | dump | safe }},
      "date_published": {{ post.published_at | dump | safe }},
      "date_modified": {{ post.updated_at | dump | safe }}
    }{% if not loop.last %},{% endif %}
    {%- endfor %}
  ]
}
{%- endmacro %}
