<!DOCTYPE html>
<html lang="{{ site.lang }}">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
    <title>{{ title or site.title }}</title>
    <meta name="description" content="{{ description or site.description or site.title }}">
    <meta name="theme-color" content="#1e2021">
    <link rel="alternate" type="application/atom+xml" title="{{ site.title }} Atom Feed" href="{{ site.url }}/feed.xml">
    <link rel="alternate" type="application/rss+xml" title="{{ site.title }} RSS Feed" href="{{ site.url }}/rss.xml">
    <link rel="alternate" type="application/feed+json" title="{{ site.title }} JSON Feed" href="{{ site.url }}/feed.json">
    {% if tagPage %}
    <link rel="alternate" type="application/atom+xml" title="{{ tagPage.name }} Atom Feed" href="{{ site.url }}/tags/{{ tagPage.slug }}/feed.xml">
    <link rel="alternate" type="application/rss+xml" title="{{ tagPage.name }} RSS Feed" href="{{ site.url }}/tags/{{ tagPage.slug }}/rss.xml">
    <link rel="alternate" type="application/feed+json" title="{{ tagPage.name }} JSON Feed" href="{{ site.url }}/tags/{{ tagPage.slug }}/feed.json">
    {% endif %}
    {% for profile in site.relMe or [] %}
    <link rel="me" href="{{ profile }}">
    {% endfor %}
    <link rel="micropub" href="{{ site.url }}/micropub">
    <link rel="webmention" href="{{ site.webmentions.endpoint }}">
    <link rel="pingback" href="{{ site.webmentions.pingback }}">
    <link rel="stylesheet" href="/assets/fontawesome/css/all.min.css">
    <script defer src="https://analytics.afterword.blog/script.js" data-website-id="28725456-c68f-411a-a1d6-0b548e1c5213"></script>
    <style>{% include "css/styles.css" %}</style>
</head>
<body class="site-shell{% if page.url == '/' %} site-home{% endif %}{% if post %} site-post{% endif %}">
    <header>{% include "partials/header.njk" %}</header>
    <hr class="site-rule">
    <main class="site-main">
        {% block content %}{{ content | safe }}{% endblock %}
    </main>
    <hr class="site-rule">
    <footer>{% include "partials/footer.njk" %}</footer>
</body>
</html>
