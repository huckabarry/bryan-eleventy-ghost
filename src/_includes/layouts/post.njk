{% extends 'layouts/default.njk' %}

{% set title = post.title %}
{% set codeinjection_head = post.codeinjection_head %}
{% set codeinjection_foot = post.codeinjection_foot %}

{% block content %}
    <article class="content content-post h-entry">
        <header class="post-header">
            <div class="post-meta-row">
                <time class="post-date dt-published" datetime="{{ post.published_at | htmlDateString }}">{{ post.published_at | dateDisplay }}</time>
                <span class="post-author p-author h-card">
                    <a class="p-name u-url" href="/">{{ post.primary_author.name | default(site.title) }}</a>
                </span>
            </div>
            {% if post.tags %}
                <div class="post-tag-list">
                    {% for tag in post.tags %}
                        {% if tag.slug != "now" and tag.visibility != "internal" %}
                        <a class="post-tag p-category" href="/tags/{{ tag.slug }}/">{{ tag.name }}</a>
                        {% endif %}
                    {% endfor %}
                </div>
            {% endif %}
            {% if not (post | hasTagSlug("status")) %}
            <h1 class="content-title">
                <a class="p-name u-url" href="{{ page.url }}">{{ title }}</a>
            </h1>
            {% endif %}
            {% if post.excerpt %}
                <p class="post-dek p-summary">{{ post.excerpt }}</p>
            {% endif %}
        </header>
        {% if post.feature_image %}
            <figure class="post-feature-image">
                <img class="u-photo" src="{{ post.feature_image }}" alt="{{ title }}">
            </figure>
        {% endif %}
        <section class="post-full-content">
            <section class="content-body load-external-scripts e-content">
                {{ content | safe }}
            </section>
        </section>
        <nav class="post-navigation">
            {% set previousPost = collections.posts | getPreviousCollectionItem(page) %}
            {% set nextPost = collections.posts | getNextCollectionItem(page) %}
            <ul>
                <li>
                    {% if previousPost %}
                    <a href="{{ previousPost.url }}">Older: {{ previousPost.title }}</a>
                    {% endif %}
                </li>
                <li>
                    {% if nextPost %}
                    <a href="{{ nextPost.url }}">Newer: {{ nextPost.title }}</a>
                    {% endif %}
                </li>
            </ul>
        </nav>
        <section
            class="webmentions"
            data-webmentions
            data-target="{{ site.url }}{{ page.url }}"
            data-api="{{ site.webmentions.api }}"
        >
            <h2 class="section-title">Responses</h2>
            <div class="webmentions-likes" data-likes hidden>
                <h3 class="webmentions-subtitle">Likes</h3>
                <div class="webmentions-facepile" data-like-list></div>
            </div>
            <div class="webmentions-comments" data-comments hidden>
                <h3 class="webmentions-subtitle">Comments</h3>
                <ol class="webmentions-comment-list" data-comment-list></ol>
            </div>
        </section>
        <script>
            (function () {
                const root = document.querySelector("[data-webmentions]");
                if (!root) return;

                const target = root.getAttribute("data-target");
                const api = root.getAttribute("data-api");
                const likesSection = root.querySelector("[data-likes]");
                const likeList = root.querySelector("[data-like-list]");
                const commentsSection = root.querySelector("[data-comments]");
                const commentList = root.querySelector("[data-comment-list]");

                fetch(`${api}?target=${encodeURIComponent(target)}&per-page=100&sort-by=published&sort-dir=up`)
                    .then((response) => response.json())
                    .then((data) => {
                        const children = Array.isArray(data.children) ? data.children : [];
                        const likes = children.filter((entry) => entry["wm-property"] === "like-of");
                        const comments = children.filter((entry) => {
                            const prop = entry["wm-property"];
                            return prop === "in-reply-to" || prop === "mention-of";
                        });

                        likes.forEach((entry) => {
                            const author = entry.author || {};
                            const link = document.createElement("a");
                            link.className = "webmentions-like";
                            link.href = entry.url || author.url || "#";
                            link.target = "_blank";
                            link.rel = "nofollow noopener noreferrer";
                            link.title = author.name || "Like";

                            if (author.photo) {
                                const img = document.createElement("img");
                                img.src = author.photo;
                                img.alt = author.name || "Like";
                                img.loading = "lazy";
                                link.appendChild(img);
                            } else {
                                link.textContent = (author.name || "?").slice(0, 1).toUpperCase();
                            }

                            likeList.appendChild(link);
                        });

                        comments.forEach((entry) => {
                            const author = entry.author || {};
                            const item = document.createElement("li");
                            item.className = "webmentions-comment";

                            const header = document.createElement("div");
                            header.className = "webmentions-comment-header";

                            if (author.photo) {
                                const img = document.createElement("img");
                                img.className = "webmentions-comment-avatar";
                                img.src = author.photo;
                                img.alt = author.name || "Comment avatar";
                                img.loading = "lazy";
                                header.appendChild(img);
                            }

                            const meta = document.createElement("div");
                            meta.className = "webmentions-comment-meta";

                            const name = document.createElement(author.url ? "a" : "span");
                            name.className = "webmentions-comment-author";
                            name.textContent = author.name || "Someone";
                            if (author.url) {
                                name.href = author.url;
                                name.target = "_blank";
                                name.rel = "nofollow noopener noreferrer";
                            }
                            meta.appendChild(name);

                            if (entry.published || entry["wm-received"]) {
                                const time = document.createElement("time");
                                time.className = "webmentions-comment-date";
                                const raw = entry.published || entry["wm-received"];
                                time.dateTime = raw;
                                time.textContent = new Date(raw).toLocaleDateString("en-US", {
                                    month: "short",
                                    day: "numeric",
                                    year: "numeric"
                                });
                                meta.appendChild(time);
                            }

                            header.appendChild(meta);
                            item.appendChild(header);

                            if (entry.content && (entry.content.html || entry.content.text)) {
                                const body = document.createElement("div");
                                body.className = "webmentions-comment-body";
                                body.innerHTML = entry.content.html || entry.content.text;
                                item.appendChild(body);
                            } else if (entry.url) {
                                const link = document.createElement("a");
                                link.className = "webmentions-comment-link";
                                link.href = entry.url;
                                link.target = "_blank";
                                link.rel = "nofollow noopener noreferrer";
                                link.textContent = "View mention";
                                item.appendChild(link);
                            }

                            commentList.appendChild(item);
                        });

                        if (likes.length) likesSection.hidden = false;
                        if (comments.length) commentsSection.hidden = false;
                    })
                    .catch(() => {});
            })();
        </script>
    </article>
{% endblock %}

{%- block seo -%}
    <!--Twitter Card-->
    <meta name="twitter:site" content="{{ site.twitter }}">
    <meta name="twitter:creator" content="{{ post.primary_author.twitter | default(site.twitter) }}">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:url" content="{{ site.url }}{{ page.url }}">
    <meta name="twitter:title" content="{{ title }} – {{ site.title }}">
    <meta name="twitter:description" content="{{ post.excerpt }}">
    <meta name="twitter:image" content="{{ post.feature_image }}">

    <!--Schema-->
    <link rel="author" href="{{ post.primary_author.website | default(site.url) }}">
    <link rel="publisher" href="{{ site.url }}">
    <meta itemprop="name" content="{{ title }} – {{ site.title }}">
    <meta itemprop="description" content="{{ post.excerpt }}">
    <meta itemprop="image" content="{{ post.feature_image }}">

    <!-- Facebook OpenGraph -->
    <meta property="og:url" content="{{ site.url }}{{ page.url }}">
    <meta property="og:type" content="website">
    <meta property="og:title" content="{{ title }} – {{ site.title }}">
    <meta property="og:image" content="{{ post.feature_image }}">
    <meta property="og:description" content="{{ post.excerpt }}">
    <meta property="og:site_name" content="{{ site.title }}">
    <meta property="og:locale" content="{{ site.lang | default('en_US') }}">
    <meta property="article:author" content="{{ site.url }}">
{%- endblock -%}
