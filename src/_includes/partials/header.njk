<header class="site-header">
    <a class="site-header-avatar-link" {% if page.url == "/" %}aria-current="page"{% endif %} href="{{ site.url }}">
        {% if site.logo %}
            <img class="avatar site-logo" src="{{ site.logo }}" alt="{{ site.title }}">
        {% else %}
            <span class="avatar avatar-fallback" aria-hidden="true">{{ (site.title or "S") | first }}</span>
        {% endif %}
    </a>
    <div class="site-header-copy">
        <div class="site-title">
            <a {% if page.url == "/" %}aria-current="page"{% endif %} href="{{ site.url }}">{{ site.title }}</a>
        </div>
        {% include 'partials/navigation.njk' %}
    </div>
</header>
