---
layout: base
eleventyExcludeFromCollections: true
permalink: /index.html
---

{% set statusPosts = collections.posts | withTagSlug("status") | withoutAnyTagSlugs("listening,now-playing") | byPublishedDateDesc %}
{% set listeningPosts = collections.posts | withAnyTagSlugs("listening,now-playing") %}
{% set latestPosts = collections.posts | withoutAnyTagSlugs("status,listening,now-playing,books,now-reading,gallery,photos") | byPublishedDateDesc %}
{% set statusPost = statusPosts[0] %}
{% set listeningPost = listeningPosts[0] %}

<section class="section-block section-block-status">
  <h2 class="section-title">Status</h2>
  <div class="home-stream">
    {% if statusPost %}
      {% set post = statusPost %}
      <article class="home-stream-item h-entry">
        <div class="home-stream-body e-content">
          <p class="home-stream-meta">
            <a class="u-url" href="{{ post | localPostUrl }}">
              <span class="post-action-icon home-stream-meta-icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="4" width="14" height="14" rx="2"></rect>
                  <path d="M7 2v4M13 2v4M3 8h14"></path>
                  <path d="M14.5 14.5l4-4 1.5 1.5-4 4-2 .5z"></path>
                </svg>
              </span>
              <time class="dt-published" datetime="{{ post.published_at | htmlDateString }}">{{ post.published_at | dateDisplay }}</time>
            </a>
          </p>
          <div class="content-body">{{ post.html | safe }}</div>
          <span class="site-visually-hidden p-author h-card">
            <a class="p-name u-url" href="{{ site.url }}">{{ site.title }}</a>
          </span>
          {% if post.tags %}
          <div class="home-stream-tags">
            {% for tag in post.tags %}
              {% if tag.visibility != "internal" and tag.slug != "now" and tag.slug != "afterword" %}
              <a class="tag-pill p-category" href="/tags/{{ tag.slug }}/">{{ tag.name }}</a>
              {% endif %}
            {% endfor %}
          </div>
          {% endif %}
        </div>
      </article>
    {% else %}
      <p>No status posts are available yet.</p>
    {% endif %}
  </div>
</section>

<section class="section-block">
  <h2 class="section-title">Latest Posts</h2>
  <ul class="site-list-of-posts h-feed">
    {% for post in latestPosts %}
      {% set listTitle = post.title | trim %}
      {% if not listTitle %}
        {% set listTitle = post | statusPreview %}
      {% endif %}
      <li class="site-list-of-posts-item h-entry">
        <time class="site-list-date dt-published" datetime="{{ post.published_at | htmlDateString }}">
          {{ post.published_at | dateDisplay }}
        </time>
        <div>
          <a class="site-list-link p-name u-url" href="{{ post | localPostUrl }}">{{ listTitle or "Untitled" }}</a>
          <span class="site-visually-hidden p-author h-card">
            <a class="p-name u-url" href="{{ site.url }}">{{ site.title }}</a>
          </span>
        </div>
      </li>
    {% else %}
      <p>No posts are available yet.</p>
    {% endfor %}
  </ul>
</section>

<section class="section-block section-block-listening">
  <h2 class="section-title">Listening</h2>
  <div class="home-stream">
    {% if listeningPost %}
      {% set post = listeningPost %}
      {% set streamImage = post | firstImage %}
      <article class="home-stream-item h-entry">
        {% if streamImage %}
          <a class="home-stream-media u-url" href="{{ post | localPostUrl }}">
            <img class="home-stream-image home-stream-image-listening u-photo" src="{{ streamImage.src }}" alt="{{ streamImage.alt }}" loading="lazy">
          </a>
        {% endif %}
        <div class="home-stream-body e-content">
          <p class="home-stream-meta">
            <a class="u-url" href="{{ post | localPostUrl }}">
              <span class="post-action-icon home-stream-meta-icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="4" width="14" height="14" rx="2"></rect>
                  <path d="M7 2v4M13 2v4M3 8h14"></path>
                  <path d="M14.5 14.5l4-4 1.5 1.5-4 4-2 .5z"></path>
                </svg>
              </span>
              <time class="dt-published" datetime="{{ post.published_at | htmlDateString }}">{{ post.published_at | dateDisplay }}</time>
            </a>
          </p>
          <div class="content-body">{{ post.html | stripFirstImage | safe }}</div>
          <span class="site-visually-hidden p-author h-card">
            <a class="p-name u-url" href="{{ site.url }}">{{ site.title }}</a>
          </span>
          {% if post.tags %}
          <div class="home-stream-tags">
            {% for tag in post.tags %}
              {% if tag.visibility != "internal" and tag.slug != "now" and tag.slug != "afterword" %}
              <a class="tag-pill p-category" href="/tags/{{ tag.slug }}/">{{ tag.name }}</a>
              {% endif %}
            {% endfor %}
          </div>
          {% endif %}
        </div>
      </article>
    {% else %}
      <p>No listening posts are available yet.</p>
    {% endif %}
  </div>
  <p class="listening-note">
    See past entries <a href="/tags/listening/">here</a> or follow along on <a href="{{ site.albumWhaleUrl }}">Album Whale</a>.
  </p>
</section>
