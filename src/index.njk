---
layout: base
eleventyExcludeFromCollections: true
permalink: /index.html
---

<section class="home-intro">
  <h1 class="home-title">{{ site.title }}</h1>
  {% if site.description %}
    <p class="home-description">{{ site.description }}</p>
  {% endif %}
</section>

<section class="section-block">
  <h2 class="section-title">Latest Posts</h2>
  <ul class="site-list-of-posts">
    {% for post in collections.posts.slice(0, 10) %}
      <li class="site-list-of-posts-item">
        <time class="site-list-date" datetime="{{ post.published_at | htmlDateString }}">
          {{ post.published_at | dateReadable }}
        </time>
        <a class="site-list-link" href="/{{ post.slug }}/">{{ post.title }}</a>
      </li>
    {% else %}
      <p>No `#now` posts are available yet.</p>
    {% endfor %}
  </ul>
</section>
