---
layout: base
eleventyExcludeFromCollections: true
permalink: /index.html
---

{% set statusPosts = collections.posts | withTagSlug("status") | withoutAnyTagSlugs("listening,now-playing") %}
{% set listeningPosts = collections.posts | withAnyTagSlugs("listening,now-playing") %}
{% set latestPosts = collections.posts | withAnyTagSlugs("afterword,now") | withoutAnyTagSlugs("status,listening,now-playing,books,now-reading,gallery,photos") %}
{% set statusPost = statusPosts[0] %}
{% set listeningPost = listeningPosts[0] %}

<section class="home-intro">
  {% if site.description %}
    <p class="home-description">{{ site.description }}</p>
  {% endif %}
</section>

<section class="section-block">
  <h2 class="section-title">Status</h2>
  <div class="home-stream">
    {% if statusPost %}
      {% set post = statusPost %}
      {% set streamImage = post | firstImage %}
      <article class="home-stream-item h-entry">
        {% if streamImage %}
          <a class="home-stream-media u-url" href="{{ post | localPostUrl }}">
            <img class="home-stream-image home-stream-image-listening u-photo" src="{{ streamImage.src }}" alt="{{ streamImage.alt }}" loading="lazy">
          </a>
        {% endif %}
        <div class="home-stream-body e-content">
          <div class="content-body">{{ post.html | safe }}</div>
          <span class="site-visually-hidden p-author h-card">
            <a class="p-name u-url" href="{{ site.url }}">{{ site.title }}</a>
          </span>
          <p class="home-stream-meta">
            <a class="u-url" href="{{ post | localPostUrl }}">
              <time class="dt-published" datetime="{{ post.published_at | htmlDateString }}">{{ post.published_at | dateDisplay }}</time>
            </a>
          </p>
        </div>
      </article>
    {% else %}
      <p>No status posts are available yet.</p>
    {% endif %}
  </div>
</section>

<section class="section-block">
  <h2 class="section-title">Latest Posts</h2>
  <ul class="site-list-of-posts h-feed">
    {% for post in latestPosts %}
      <li class="site-list-of-posts-item h-entry">
        <time class="site-list-date dt-published" datetime="{{ post.published_at | htmlDateString }}">
          {{ post.published_at | dateDisplay }}
        </time>
        <div>
          <a class="site-list-link p-name u-url" href="{{ post | localPostUrl }}">{{ post.title }}</a>
          <span class="site-visually-hidden p-author h-card">
            <a class="p-name u-url" href="{{ site.url }}">{{ site.title }}</a>
          </span>
        </div>
      </li>
    {% else %}
      <p>No posts are available yet.</p>
    {% endfor %}
  </ul>
</section>

<section class="section-block">
  <h2 class="section-title">Listening</h2>
  <div class="home-stream">
    {% if listeningPost %}
      {% set post = listeningPost %}
      {% set streamImage = post | firstImage %}
      <article class="home-stream-item h-entry">
        {% if streamImage %}
          <a class="home-stream-media u-url" href="{{ post | localPostUrl }}">
            <img class="home-stream-image u-photo" src="{{ streamImage.src }}" alt="{{ streamImage.alt }}" loading="lazy">
          </a>
        {% endif %}
        <div class="home-stream-body e-content">
          {% if post.excerpt %}
            <p>{{ post.excerpt }}</p>
          {% else %}
            <p><a class="p-name u-url" href="{{ post | localPostUrl }}">{{ post.title }}</a></p>
          {% endif %}
          <span class="site-visually-hidden p-author h-card">
            <a class="p-name u-url" href="{{ site.url }}">{{ site.title }}</a>
          </span>
          <p class="home-stream-meta">
            <a class="u-url" href="{{ post | localPostUrl }}">
              <time class="dt-published" datetime="{{ post.published_at | htmlDateString }}">{{ post.published_at | dateDisplay }}</time>
            </a>
          </p>
        </div>
      </article>
    {% else %}
      <p>No listening posts are available yet.</p>
    {% endif %}
  </div>
  <p class="listening-note">
    See past entries <a href="/tags/listening/">here</a> or follow along on <a href="{{ site.albumWhaleUrl }}">Album Whale</a>.
  </p>
</section>
