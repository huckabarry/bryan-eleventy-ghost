---
layout: base
eleventyExcludeFromCollections: true
pagination:
  data: collections.posts  # Change this from ghostPosts to posts
  size: 10
  alias: posts
permalink: "{% if pagination.pageNumber > 0 %}/{{ pagination.pageNumber + 1 }}{% endif %}/index.html"
---

<div class="post-list">
  <ul>
  {% for post in posts %}
    <li>
      <a href="/{{ post.slug }}/">
        <h2>{{ post.title }}</h2>
        <p>{{ post.excerpt }}</p>
      </a>
    </li>
  {% endfor %}
  </ul>
</div>
