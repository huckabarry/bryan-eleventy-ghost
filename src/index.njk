---
layout: base
eleventyExcludeFromCollections: true
pagination:
  data: collections.ghostPosts
  size: 10
  alias: posts
permalink: "{% if pagination.pageNumber > 0 %}/{{ pagination.pageNumber + 1 }}{% endif %}/index.html"
---

<div class="post-list">
  <ul>
  {% for post in posts %}
    <li>
      <a href="{{ post.url }}">
        <h2>{{ post.title }}</h2>
        <p>{{ post.excerpt }}</p>
      </a>
    </li>
  {% endfor %}
  </ul>
</div>

{% include "partials/scroll-up-arrow.njk" %}
{% include "partials/pagination.njk" %}
