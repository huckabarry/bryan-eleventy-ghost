---
layout: base
permalink: /now/index.html
title: Now
description: "The latest now post."
---

{% set nowPosts = collections.posts | withTagSlug("now") %}
{% set nowPost = nowPosts[0] %}
{% set readingPosts = collections.posts | withAnyTagSlugs("books,now-reading") | byPublishedDateDesc %}
{% set listeningPosts = collections.posts | withAnyTagSlugs("listening,now-playing") | byPublishedDateDesc %}
{% set readingPost = readingPosts[0] %}
{% set listeningPost = listeningPosts[0] %}

<section class="section-block">
  <h1 class="section-title">Now</h1>

  {% if nowPost %}
    <article class="content content-page h-entry">
      <a class="site-visually-hidden u-uid" href="{{ site.url }}{{ nowPost | localPostUrl }}">{{ site.url }}{{ nowPost | localPostUrl }}</a>
      <span class="site-visually-hidden p-name">{{ nowPost.title | default("Now update") }}</span>
      <div class="post-meta-row">
        <time class="post-date dt-published" datetime="{{ nowPost.published_at | htmlDateString }}">{{ nowPost.published_at | dateDisplay }}</time>
        <span class="site-visually-hidden p-author h-card">
          <a class="p-name u-url" href="{{ site.url }}">{{ site.title }}</a>
        </span>
      </div>
      <div class="post-full-content">
        <section class="content-body e-content">
          {{ nowPost.html | safe }}
        </section>
      </div>
      {% if nowPost.tags %}
        <div class="post-tag-list">
          {% for tag in nowPost.tags %}
            {% if tag.visibility != "internal" %}
            {% if tag.slug != "afterword" and tag.visibility != "internal" %}
            <a class="post-tag tag-pill p-category" href="/tags/{{ tag.slug }}/">{{ tag.name }}</a>
            {% endif %}
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}
      <p class="home-stream-meta">
        <a class="u-url" href="{{ nowPost | localPostUrl }}">Permalink</a>
      </p>
      <p class="tag-feed-note">Follow the <a href="/tags/now/rss.xml">RSS feed</a> or <a href="/tags/now/feed.json">JSON feed</a> for this tag.</p>
    </article>
  {% else %}
    <p>No now post is available yet.</p>
  {% endif %}
</section>

{% if readingPost or listeningPost %}
<section class="section-block section-block-listening">
  <h2 class="section-title">Latest Media</h2>
  <div class="cover-grid cover-grid-listening h-feed now-media-grid">
    {% if readingPost %}
      {% set post = readingPost %}
      {% set coverImage = post | firstImage %}
      <article class="cover-card h-entry">
        <a class="cover-card-link u-url" href="{{ post | localPostUrl }}">
          {% if coverImage %}
          <img
            class="cover-card-image u-photo"
            src="{{ coverImage.src }}"
            alt="{{ coverImage.alt }}"
            loading="lazy"
          >
          {% else %}
          <span class="cover-card-image cover-card-image-fallback" aria-hidden="true"></span>
          {% endif %}
          <span class="cover-card-title p-name">{{ post | mediaCardTitle }}</span>
          {% set mediaSubtitle = post | mediaCardSubtitle %}
          {% if mediaSubtitle %}
          <span class="cover-card-subtitle">{{ mediaSubtitle }}</span>
          {% endif %}
          <span class="cover-card-meta">{{ post.published_at | dateDisplay }}</span>
        </a>
        <time class="site-visually-hidden dt-published" datetime="{{ post.published_at | htmlDateString }}">{{ post.published_at | dateDisplay }}</time>
      </article>
    {% endif %}

    {% if listeningPost %}
      {% set post = listeningPost %}
      {% set coverImage = post | firstImage %}
      <article class="cover-card h-entry">
        <a class="cover-card-link u-url" href="{{ post | localPostUrl }}">
          {% if coverImage %}
          <img
            class="cover-card-image u-photo"
            src="{{ coverImage.src }}"
            alt="{{ coverImage.alt }}"
            loading="lazy"
          >
          {% else %}
          <span class="cover-card-image cover-card-image-fallback" aria-hidden="true"></span>
          {% endif %}
          <span class="cover-card-title p-name">{{ post | mediaCardTitle }}</span>
          {% set mediaSubtitle = post | mediaCardSubtitle %}
          {% if mediaSubtitle %}
          <span class="cover-card-subtitle">{{ mediaSubtitle }}</span>
          {% endif %}
          <span class="cover-card-meta">{{ post.published_at | dateDisplay }}</span>
        </a>
        <time class="site-visually-hidden dt-published" datetime="{{ post.published_at | htmlDateString }}">{{ post.published_at | dateDisplay }}</time>
      </article>
    {% endif %}
  </div>
  <p class="listening-note">Browse <a href="/books/">Library</a> and <a href="/tags/listening/">Listening History</a>.</p>
</section>
{% endif %}
