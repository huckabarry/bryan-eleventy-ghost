---
layout: base
permalink: /now/index.html
title: Now
description: "The latest now post."
---

{% set nowPosts = collections.posts | withTagSlug("now") %}
{% set nowPost = nowPosts[0] %}

<section class="section-block">
  <h1 class="section-title">Now</h1>

  {% if nowPost %}
    <article class="content content-page h-entry">
      <a class="site-visually-hidden u-uid" href="{{ site.url }}{{ nowPost | localPostUrl }}">{{ site.url }}{{ nowPost | localPostUrl }}</a>
      <div class="post-meta-row">
        <time class="post-date dt-published" datetime="{{ nowPost.published_at | htmlDateString }}">{{ nowPost.published_at | dateDisplay }}</time>
        <span class="site-visually-hidden p-author h-card">
          <a class="p-name u-url" href="{{ site.url }}">{{ site.title }}</a>
        </span>
      </div>
      <div class="post-full-content">
        <section class="content-body e-content">
          {{ nowPost.html | safe }}
        </section>
      </div>
      <p class="home-stream-meta">
        <a class="u-url" href="{{ nowPost | localPostUrl }}">Permalink</a>
      </p>
    </article>
  {% else %}
    <p>No now post is available yet.</p>
  {% endif %}
</section>
