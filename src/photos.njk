---
layout: base
permalink: /photos/index.html
title: Photos
description: "A masonry-style gallery built from all images in gallery posts."
---

<section class="section-block photo-page">
  <h1 class="section-title">Photos</h1>
  <div class="photo-grid">
    {% for photo in collections.photoPosts %}
      <article class="photo-card h-entry">
        <a
          class="photo-card-link u-url"
          href="{{ photo | localPostUrl }}"
          data-photo-trigger
          data-photo-src="{{ photo.image.src }}"
          data-photo-alt="{{ photo.image.alt }}"
          data-photo-post-url="{{ photo | localPostUrl }}"
          data-photo-post-title="{{ photo.title }}"
        >
          <img
            class="photo-card-image u-photo"
            src="{{ photo.image.src }}"
            alt="{{ photo.image.alt }}"
            loading="lazy"
          >
        </a>
        <span class="site-visually-hidden p-name">{{ photo.title }}</span>
        <time class="site-visually-hidden dt-published" datetime="{{ photo.published_at | htmlDateString }}">
          {{ photo.published_at | dateDisplay }}
        </time>
      </article>
    {% else %}
      <p>No photo posts are available yet.</p>
    {% endfor %}
  </div>
</section>

<div class="photo-lightbox" data-photo-lightbox hidden>
  <button class="photo-lightbox-close" type="button" aria-label="Close photos" data-photo-close>&times;</button>
  <button class="photo-lightbox-nav photo-lightbox-prev" type="button" aria-label="Previous photo" data-photo-prev>&larr;</button>
  <div class="photo-lightbox-stage">
    <img class="photo-lightbox-image" src="" alt="" data-photo-image>
    <a class="photo-lightbox-post-link" href="#" data-photo-post-link hidden>View post</a>
  </div>
  <button class="photo-lightbox-nav photo-lightbox-next" type="button" aria-label="Next photo" data-photo-next>&rarr;</button>
</div>

<script>
  (function () {
    const triggers = Array.from(document.querySelectorAll("[data-photo-trigger]"));
    const lightbox = document.querySelector("[data-photo-lightbox]");
    if (!triggers.length || !lightbox) return;

    const image = lightbox.querySelector("[data-photo-image]");
    const postLink = lightbox.querySelector("[data-photo-post-link]");
    const closeButton = lightbox.querySelector("[data-photo-close]");
    const prevButton = lightbox.querySelector("[data-photo-prev]");
    const nextButton = lightbox.querySelector("[data-photo-next]");
    let currentIndex = 0;

    function render(index) {
      const trigger = triggers[index];
      if (!trigger) return;

      currentIndex = index;
      image.src = trigger.getAttribute("data-photo-src") || "";
      image.alt = trigger.getAttribute("data-photo-alt") || "";

      const url = trigger.getAttribute("data-photo-post-url");
      const title = trigger.getAttribute("data-photo-post-title") || "View post";
      if (url) {
        postLink.href = url;
        postLink.textContent = title;
        postLink.hidden = false;
      } else {
        postLink.hidden = true;
      }
    }

    function open(index) {
      render(index);
      lightbox.hidden = false;
      document.body.classList.add("photo-lightbox-open");
    }

    function close() {
      lightbox.hidden = true;
      document.body.classList.remove("photo-lightbox-open");
      image.src = "";
      image.alt = "";
    }

    function step(direction) {
      const nextIndex = (currentIndex + direction + triggers.length) % triggers.length;
      render(nextIndex);
    }

    triggers.forEach((trigger, index) => {
      trigger.addEventListener("click", (event) => {
        event.preventDefault();
        open(index);
      });
    });

    closeButton.addEventListener("click", close);
    prevButton.addEventListener("click", () => step(-1));
    nextButton.addEventListener("click", () => step(1));

    lightbox.addEventListener("click", (event) => {
      if (event.target === lightbox) close();
    });

    document.addEventListener("keydown", (event) => {
      if (lightbox.hidden) return;
      if (event.key === "Escape") close();
      if (event.key === "ArrowLeft") step(-1);
      if (event.key === "ArrowRight") step(1);
    });
  })();
</script>
